<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ModelSettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="模型设置" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 语音转字幕高级配置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="语音转字幕高级配置"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="配置固定分段等通用识别选项"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnSpeechAdvancedSettings"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="打开配置" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Whisper 模型文件 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAsrModelTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Whisper 模型"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />

                            <TextView
                                android:id="@+id/tvEncoderLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Encoder 模型"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface" />

                            <LinearLayout
                                android:id="@+id/layoutModelFile"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvEncoderFile"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:ellipsize="middle"
                                    android:singleLine="true"
                                    android:text="未选择"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="12sp" />

                                <Button
                                    android:id="@+id/btnSelectEncoder"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="选择 Encoder" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:gravity="end"
                            android:orientation="vertical">

                            <Button
                                android:id="@+id/btnWhisperConfig"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:text="配置" />

                            <Button
                                android:id="@+id/btnSwitchAsrModel"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="0dp"
                                android:text="切换模型" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Decoder -->
                    <LinearLayout
                        android:id="@+id/layoutDecoder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Decoder 模型"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tvDecoderFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="未选择"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:ellipsize="middle"
                        android:singleLine="true" />

                    <Button
                        android:id="@+id/btnSelectDecoder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="选择 Decoder"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    </LinearLayout>

                    <!-- Tokens -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Tokens 文件"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tvTokensFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="未选择"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:ellipsize="middle"
                        android:singleLine="true" />

                    <Button
                        android:id="@+id/btnSelectTokens"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="选择 Tokens"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    <TextView
                        android:id="@+id/tvQuickDownload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="end"
                        android:text="快速下载"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvModelGuide"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="end"
                        android:text="帮助"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- VAD 模型 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VAD 模型（可选，已内置）"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tvVadFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="使用内置模型"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:ellipsize="middle"
                        android:singleLine="true" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnSelectVad"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="选择外部 VAD 模型" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbUseBuiltInVad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="使用内置"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- VAD 参数设置 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VAD 参数设置"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />

                    <!-- VAD 阈值 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="检测阈值"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="值越低越容易检测到语音，但可能误判噪音"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderVadThreshold"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0.1"
                            android:valueTo="0.9"
                            android:stepSize="0.05"
                            android:value="0.3" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etVadThreshold"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0.30"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:inputType="numberDecimal"
                                android:maxLines="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- 最小静音时长 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="最小静音时长"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="静音超过此时长才会分段"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderMinSilence"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0.1"
                            android:valueTo="2.0"
                            android:stepSize="0.1"
                            android:value="0.3" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            app:suffixText="秒"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMinSilence"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0.30"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:inputType="numberDecimal"
                                android:maxLines="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- 最小语音时长 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="最小语音时长"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="短于此时长的语音会被忽略"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderMinSpeech"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0.05"
                            android:valueTo="1.0"
                            android:stepSize="0.05"
                            android:value="0.25" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                            app:suffixText="秒">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMinSpeech"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0.25"
                                android:textSize="14sp"
                                android:inputType="numberDecimal"
                                android:gravity="center"
                                android:maxLines="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- 最大语音时长 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="最大语音时长"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="超过此时长会强制分段"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderMaxSpeech"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="5.0"
                            android:valueTo="60.0"
                            android:stepSize="5.0"
                            android:value="10.0" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                            app:suffixText="秒">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMaxSpeech"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="10.0"
                                android:textSize="14sp"
                                android:inputType="numberDecimal"
                                android:gravity="center"
                                android:maxLines="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
